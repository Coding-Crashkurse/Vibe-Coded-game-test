  "version": 1,
  "_comment": "SPEC v5 §5.1 — single source of truth for every spoken line. Regeneration is manifest-driven: add a line entry, rerun the voice package. 'status' is 'present' (file exists on disk) or 'pending' (not generated yet). sfx.gd never depends on this file: a missing manifest falls back to the <char>_<kind>.mp3 naming convention.",
  "target_lufs": -16.0,
  "format": "mp3, 44.1 kHz, mono",
  "voice_dir": "res://assets/sfx/voice/",
  "archive_dir": "res://assets/sfx/voice/_archive/de/",
  "kinds": {
    "select": "unit selected — 2 variants",
    "move_ack": "move order acknowledged — 2 variants; variant 1 lives in the legacy <char>_reply.mp3 files",
    "quote": "hiring-screen signature line — 1, text verbatim from Db.MERCS[].quote",
    "pain": "took a hit — 2 variants, wordless",
    "death": "killed — 1, wordless",
    "spot": "EXTRA kind, not in the spec list: enemy-sighting callout. Working content — keep it."
  },
  "variant_naming": "variant 1 = <char>_<kind>.mp3, variant 2+ = <char>_<kind>_<n>.mp3",
