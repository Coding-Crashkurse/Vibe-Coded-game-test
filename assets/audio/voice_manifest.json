    "tobias": {
      "voice_id": "",
      "voice_ref": "opa",
      "voice_design": "Old fisherman, gravelly warm voice, slow, tired but unbroken. Village elder of Rookhaven. Borrows the 'opa' voice — no separate generation needed.",
      "_note": "Internal unit id stays 'otto' in Db/Game so the test harness keeps working; the player only ever sees 'Tobias Rook'. info_1..3 texts are verbatim from Db.TOBIAS_DIALOG, rescue from Db.OTTO.quote.",
      "lines": {
        "rescue": {
          "text": "Took you long enough.",
          "file": "tobias_rescue.mp3",
          "status": "present"
        },
        "info_1": {
          "text": "Helix owns this island now. The mines, the barracks, that manor out on the rock.",
          "file": "tobias_1.mp3",
          "status": "present"
        },
        "info_2": {
          "text": "My daughter. They took her — because of her research. I don't know where.",
          "file": "tobias_2.mp3",
          "status": "present"
        },
        "info_3": {
          "text": "Widow's Vein and Stoneglint. Diamonds. That's what pays for all of it. Whoever holds the mines holds the island.",
          "file": "tobias_3.mp3",
          "status": "present"
        },
        "base_welcome": {
          "text": "It isn't much. But they never look for anyone down here.",
          "file": "tobias_base_welcome.mp3",
          "status": "present"
        },
        "battle_1": {
          "text": "Give me a rifle. I'm not hiding again.",
          "file": "tobias_battle_1.mp3",
          "status": "present"
        },
        "battle_2": {
          "text": "That's for my daughter.",
          "file": "tobias_battle_2.mp3",
          "status": "present"
        }
      }
    },
    "narrator": {
      "voice_id": "onwK4e9ZLuTAKqWW03F9",
      "voice_design": "Deep weathered war-documentary narrator, measured. Unhurried, no theatrics — states facts that have already gone badly.",
      "lines": {
        "intro": {
          "text": "Ashveil Isle. A fishing island with two diamond mines and one owner. Helix Bioscience took the village of Rookhaven a month ago. Your contact is still down there — if he's still breathing. Insert at the landing zone. Get him out.",
          "file": "narrator_intro.mp3",
          "status": "present"
        },
        "demo_end": {
          "text": "Rookhaven is free. Maren Rook is out there somewhere. And the mines keep digging — for Helix. — To be continued.",
          "file": "narrator_demo_end.mp3",
          "status": "present"
        }
      },
